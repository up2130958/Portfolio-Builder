# ============================================================
# Application configuration
# Copy this file to .env and fill in your values
# ============================================================

# Server port (required)
PORT=3000

# Node environment: development | production
NODE_ENV=production

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Session secret - use a long random string (required)
SESSION_SECRET=change-me-to-a-long-random-secret-value

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/personal_site

# Admin credentials used by the seed script
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# CORS origin (optional, defaults to allow all)
# CORS_ORIGIN=https://yourdomain.com
